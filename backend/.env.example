PINATA_JWT=your_pinata_jwt_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🌍 How to Enable Global Cross-Device Mail
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DMail uses Pinata to pin mail content to the public
# IPFS network securely. This is required for messages
# to be readable across different devices and networks.
#
# 1. Create a free account at: https://app.pinata.cloud/register
# 2. Go to "API Keys" -> "New Key"
# 3. Enable "pinJSONToIPFS" and "pinFileToIPFS"
# 4. Copy the long JWT token
# 5. Rename this file to `.env` and paste your JWT above
# 6. Restart this relay server
#
# Since this JWT is securely stored on your backend, your
# end users do NOT need to configure anything. They will 
# automatically get global communication!
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
